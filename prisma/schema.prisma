// Reele Video Engine - Database Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  role          String    @default("user") // user, admin
  credits       Int       @default(9999)
  plan          String    @default("free") // free, pro, enterprise
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[]
  brandKits     BrandKit[]
  apiKeys       ApiKey[]
  usageRecords  UsageRecord[]
}

model BrandKit {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  primaryColor String  @default("#1A2B5F")
  secondaryColor String @default("#FFFFFF")
  accentColor  String  @default("#FF6B35")
  fontFamily   String  @default("Inter")
  watermarkUrl String?
  watermarkPosition String @default("bottom-right")
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects    Project[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  topic       String
  audience    String
  platform    String   @default("facebook_reels") // facebook_reels, instagram_reels, tiktok, youtube_shorts
  language    String   @default("en") // en, ar
  duration    Int      @default(30) // seconds
  cta         String?
  status      String   @default("draft") // draft, generating, rendering, completed, failed
  sceneJson   String?  // JSON string of scene breakdown
  scriptText  String?  // Generated script
  hookText    String?  // Generated hook
  captionText String?  // Generated social media caption
  hashtags    String?  // Generated hashtags
  thumbnailUrl String?
  videoUrl    String?
  voiceoverUrl String?
  subtitleSrt String?
  errorMessage String?
  userId      String
  brandKitId  String?
  templateId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  brandKit    BrandKit? @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  template    Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  assets      Asset[]
  scenes      Scene[]
  analytics   VideoAnalytics?
}

model Template {
  id          String   @id @default(cuid())
  name        String
  type        String   // educational, product_promo, data_viz, testimonial, corporate, travel, chemistry
  description String?
  thumbnailUrl String?
  config      String   // JSON string with template configuration
  supportsRtl Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
}

model Scene {
  id          String   @id @default(cuid())
  projectId   String
  sceneIndex  Int
  start       Float    // start time in seconds
  end         Float    // end time in seconds
  type        String   // hook, problem, solution, proof, cta, transition
  text        String
  imageUrl    String?
  animation   String?  // JSON animation config
  duration    Float    // computed duration
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // image, voiceover, subtitle, music, thumbnail
  url         String
  fileName    String?
  fileSize    Int?
  mimeType    String?
  metadata    String?  // JSON metadata
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model VideoAnalytics {
  id          String   @id @default(cuid())
  projectId   String   @unique
  views       Int      @default(0)
  likes       Int      @default(0)
  shares      Int      @default(0)
  completionRate Float @default(0)
  platformMetrics String? // JSON platform-specific metrics
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  provider    String   // gemini, claude, openai, pollinations, stable_diffusion
  isActive    Boolean  @default(true)
  userId      String
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  action      String   // generate_content, generate_assets, render_video, generate_caption
  creditsUsed Int      @default(1)
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkflowLog {
  id          String   @id @default(cuid())
  projectId   String?
  workflow    String   // generate_content, generate_assets, render_video, generate_caption
  step        String
  status      String   // pending, running, completed, failed
  input       String?  // JSON
  output      String?  // JSON
  error       String?
  duration    Int?     // milliseconds
  createdAt   DateTime @default(now())
}
