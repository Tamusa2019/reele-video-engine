# =============================================================================
# .dockerignore - Exclude unnecessary files from Docker build context
# Reduces build time and image size for Hugging Face Spaces deployment
# =============================================================================

# Dependencies (will be installed fresh in the container)
node_modules
npm-debug.log*

# Build output (will be built fresh in the container)
.next
out

# Database (will be created in persistent storage /data)
db/*.db
db/*.db-journal

# Uploads (will be stored in persistent storage /data)
upload/

# Download/generated files
download/

# Git
.git
.gitignore

# CI/CD
.github

# IDE
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Environment files (secrets set via HF Space settings)
.env
.env.*
!.env.example

# Docker files (avoid recursive copies)
Dockerfile
Dockerfile.hf
docker-compose*.yml

# Render config
render.yaml

# Vercel config
vercel.json

# Logs
*.log
dev.log

# Documentation
README.md
README_HF.md
worklog.md
agent-ctx/

# Example files
examples/

# Caddyfile (not needed in container)
Caddyfile

# Lock files other than npm
bun.lock
