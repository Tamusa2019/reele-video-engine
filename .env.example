# =============================================================================
# Reele Video Engine - Environment Variables Template
# Copy this file to .env and fill in the values for your deployment
# =============================================================================

# ─── DATABASE ────────────────────────────────────────────────────────────────
# For Vercel: Use Vercel Postgres (auto-configured when you add the integration)
# For Render: SQLite works fine for MVP with a persistent disk
#   file:./db/custom.db
# For production: Use a managed PostgreSQL
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=file:./db/custom.db

# ─── UPLOAD DIRECTORY ────────────────────────────────────────────────────────
# Where generated images, voiceovers, etc. are stored
# Default: ./upload (relative to app root)
# Vercel NOTE: /tmp is the only writable directory, but files are ephemeral!
#   For Vercel, you'll need S3/R2 for persistent file storage
# UPLOAD_DIR=./upload

# ─── DATABASE DIRECTORY (SQLite only) ───────────────────────────────────────
# DB_DIR=./db
